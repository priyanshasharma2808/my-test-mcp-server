{
  "openapi": "3.0.0",
  "info": {
    "title": "Weather data fetcher",
    "version": "1.0.0"
  },
  "paths": {
    "/getWeatherDataByCityName": {
      "post": {
        "summary": "Get weather data by city name",
        "operationId": "getWeatherDataByCityName",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "city": {
                    "type": "string"
                  }
                },
                "required": [
                  "city"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Weather data response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "Temp": {
                      "type": "string",
                      "nullable": true
                    },
                    "Forcast": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Agentic"
    },
    {
      "name": "McpSse"
    }
  ]
}