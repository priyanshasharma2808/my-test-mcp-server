{
  "swagger": "2.0",
  "info": {
    "title": "Weather data fetcher",
    "version": "1.0.0"
  },
  "paths": {
    "/getWeatherDataByCityName": {
      "post": {
        "tags": [
          "Agentic",
          "McpSse"
        ],
        "summary": "Get weather data by city name",
        "description": "Fetches weather data for a given city name",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "city": {
                  "type": "string"
                }
              },
              "required": [
                "city"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "schema": {
              "type": "object",
              "properties": {
                "Temp": {
                  "type": "string",
                  "nullable": true
                },
                "Forcast": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}